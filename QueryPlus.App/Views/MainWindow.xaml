<Window x:Class="QueryPlus.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:behaviors="clr-namespace:QueryPlus.App.Behaviors"
        xmlns:vm="clr-namespace:QueryPlus.App.ViewModels"
        xmlns:domain="clr-namespace:QueryPlus.Core.Domain;assembly=QueryPlus.Core"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="QueryPlus" Height="720" Width="1160"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ExecuteCommand}" />
    </Window.InputBindings>

    <DockPanel>
        <!-- Toolbar: a WrapPanel so items wrap to a second row on narrow widths
             instead of being clipped into a ToolBar overflow. -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1" Padding="8,6">
            <Border.Resources>
                <!-- BasedOn keeps the Fluent theme's button visuals; we only add spacing. -->
                <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                    <Setter Property="Margin" Value="3,0" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                </Style>
                <Style x:Key="Sep" TargetType="Border">
                    <Setter Property="Width" Value="1" />
                    <Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
                    <Setter Property="Margin" Value="8,4" />
                </Style>
                <Style x:Key="Lbl" TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="Margin" Value="4,0,6,0" />
                </Style>
            </Border.Resources>
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="List:" Style="{StaticResource Lbl}" />
                <ComboBox Width="190" VerticalAlignment="Center"
                          ItemsSource="{Binding Lists}"
                          SelectedItem="{Binding SelectedList}" DisplayMemberPath="Name" />
                <Border Style="{StaticResource Sep}" />
                <TextBlock Text="Parallelism:" Style="{StaticResource Lbl}" />
                <TextBox Width="56" VerticalAlignment="Center"
                         Text="{Binding MaxParallel, UpdateSourceTrigger=PropertyChanged}" />
                <Border Style="{StaticResource Sep}" />
                <TextBlock Text="On error:" Style="{StaticResource Lbl}" />
                <ComboBox VerticalAlignment="Center" Width="140"
                          SelectedValue="{Binding ErrorPolicy}" SelectedValuePath="Tag"
                          ToolTip="What to do when a script errors on a database">
                    <ComboBoxItem Content="Stop database" Tag="{x:Static domain:ScriptErrorPolicy.StopTarget}" />
                    <ComboBoxItem Content="Continue" Tag="{x:Static domain:ScriptErrorPolicy.Continue}" />
                    <ComboBoxItem Content="Stop run" Tag="{x:Static domain:ScriptErrorPolicy.StopRun}" />
                </ComboBox>
                <Border Style="{StaticResource Sep}" />
                <Button Content="▶  Execute (F5)" Command="{Binding ExecuteCommand}"
                        Style="{StaticResource AccentButtonStyle}" Margin="3,0" VerticalAlignment="Center" />
                <Button Content="■  Stop" Command="{Binding StopCommand}" />
                <Border Style="{StaticResource Sep}" />
                <Button Content="Manage Targets…" Command="{Binding ManageTargetsCommand}" />
                <Button Content="Export CSV…" Command="{Binding ExportCsvCommand}"
                        ToolTip="Save all result rows (beyond the on-screen cap) to a CSV file" />
                <Button Content="Export Excel…" Command="{Binding ExportExcelCommand}"
                        ToolTip="Save all result rows to an .xlsx workbook" />
            </WrapPanel>
        </Border>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <ProgressBar Width="160" Height="16" Minimum="0" Maximum="100"
                             Value="{Binding ProgressValue}" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock>
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0}/{1} targets">
                            <Binding Path="CompletedTargets" Mode="OneWay" />
                            <Binding Path="TotalTargets" Mode="OneWay" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding ElapsedText, Mode=OneWay, StringFormat=Elapsed: {0}}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
        </StatusBar>

        <!-- Main content: left targets | right editor/results -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="160" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: distribution list + targets tree -->
            <DockPanel Grid.Column="0" Margin="4">
                <TextBlock DockPanel.Dock="Top" Text="Targets (checked ones run)" FontWeight="Bold"
                           Margin="2" TextWrapping="Wrap" />
                <WrapPanel DockPanel.Dock="Top" Margin="2,0,2,2">
                    <Button Content="✓ All" Command="{Binding CheckAllTargetsCommand}" Margin="0,0,3,0" Padding="6,1" />
                    <Button Content="✗ All" Command="{Binding UncheckAllTargetsCommand}" Padding="6,1" />
                </WrapPanel>
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1"
                        CornerRadius="4">
                    <TreeView ItemsSource="{Binding SelectedList.ServerGroups}">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type vm:ServerGroupViewModel}"
                                                      ItemsSource="{Binding Databases}">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding AllIncluded}" IsThreeState="False"
                                              Style="{StaticResource CompactCheckBox}" Margin="0,0,6,0"
                                              ToolTip="Include/exclude all of this server's databases" />
                                    <TextBlock Text="🖥 " />
                                    <TextBlock Text="{Binding Server}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                            <DataTemplate DataType="{x:Type vm:TargetViewModel}">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding IncludeInRun}"
                                              Style="{StaticResource CompactCheckBox}" Margin="0,0,6,0"
                                              ToolTip="Include this database in the run" />
                                    <TextBlock Text="{Binding Database}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </Border>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" />

            <!-- Right: editor over results -->
            <Grid Grid.Column="2" Margin="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="120" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" MinHeight="120" />
                </Grid.RowDefinitions>

                <!-- Scripts list + editor (scales to dozens of scripts) -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" MinWidth="150" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Margin="0,0,2,0">
                        <TextBlock DockPanel.Dock="Top" Text="Scripts (checked ones run, in order)"
                                   FontWeight="Bold" Margin="2" TextWrapping="Wrap" />
                        <WrapPanel DockPanel.Dock="Top" Margin="2,0,2,2">
                            <Button Content="New" Command="{Binding NewTabCommand}" Margin="0,0,3,3" Padding="6,1" />
                            <Button Content="Files…" Command="{Binding OpenFileCommand}" Margin="0,0,3,3" Padding="6,1" />
                            <Button Content="Folder…" Command="{Binding OpenFolderCommand}" Margin="0,0,3,3" Padding="6,1" />
                            <Button Content="Remove" Command="{Binding RemoveSelectedScriptsCommand}"
                                    Margin="0,0,3,3" Padding="6,1" ToolTip="Remove the highlighted script(s)" />
                            <Button Content="✓ All" Command="{Binding CheckAllCommand}" Margin="0,0,3,3" Padding="6,1" />
                            <Button Content="✗ All" Command="{Binding UncheckAllCommand}" Margin="0,0,3,3" Padding="6,1" />
                        </WrapPanel>
                        <ListBox ItemsSource="{Binding ScriptTabs}" SelectedItem="{Binding SelectedTab}"
                                 SelectionMode="Extended"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource DefaultListBoxItemStyle}">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="Padding" Value="8,4" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ScriptTabViewModel}">
                                    <DockPanel LastChildFill="True">
                                        <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IncludeInRun}"
                                                  Style="{StaticResource CompactCheckBox}" Margin="0,0,6,0"
                                                  ToolTip="Include this script in the run" />
                                        <StackPanel>
                                            <DockPanel LastChildFill="True">
                                                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="4,0,0,0"
                                                           Foreground="Gray" Text="{Binding ResultRowCount, StringFormat={}{0} rows}" />
                                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasErrors}" Value="True">
                                                                    <Setter Property="Foreground" Value="#FFB00000" />
                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DockPanel>
                                            <ProgressBar Height="3" Minimum="0" Maximum="100" Margin="0,2,0,0"
                                                         Value="{Binding ScriptProgressValue, Mode=OneWay}"
                                                         BorderThickness="0" Background="Transparent" />
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" />

                    <avalonEdit:TextEditor Grid.Column="2"
                        behaviors:AvalonEditBehavior.BoundText="{Binding SelectedTab.Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        behaviors:AvalonEditBehavior.HighlightingName="TSQL"
                        ShowLineNumbers="True" FontFamily="Consolas" FontSize="13"
                        WordWrap="False"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Auto" />
                </Grid>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                              VerticalAlignment="Center" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" />

                <!-- Results / Messages / Errors -->
                <TabControl Grid.Row="2" SelectedIndex="{Binding SelectedResultTab}">
                    <TabItem Header="Results">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="{Binding ResultsTruncatedText}"
                                       Background="#FFFFF4CE" Foreground="#FF5A4A00" Padding="8,4"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,4,2">
                                <TextBlock Text="Script:" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <ComboBox Width="220" ItemsSource="{Binding ScriptFilters}"
                                          SelectedItem="{Binding ScriptFilter}" />
                            </StackPanel>
                            <DataGrid x:Name="ResultsGrid" ItemsSource="{Binding ResultsView}"
                                      AutoGenerateColumns="True" IsReadOnly="True"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      SelectionMode="Extended" SelectionUnit="FullRow"
                                      ClipboardCopyMode="IncludeHeader"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling" />
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Messages">
                        <ListBox ItemsSource="{Binding Messages}" FontFamily="Consolas"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                    </TabItem>
                    <TabItem Header="Errors">
                        <ListBox ItemsSource="{Binding Errors}" FontFamily="Consolas"
                                 Foreground="#FFB00000"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
