<?xml version="1.0" encoding="utf-8"?>
<!--
  Self-contained, single-file publish profile for win-x64.
  Produces one .exe with no .NET runtime install required.

    dotnet publish QueryPlus.App/QueryPlus.App.csproj -p:PublishProfile=win-x64
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <PublishDir>bin\Release\net8.0-windows\publish\win-x64\</PublishDir>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <!-- WPF + SqlClient carry native libs; extract them at first run. -->
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- Embed symbols in the exe so the publish folder is a single shippable file. -->
    <DebugType>embedded</DebugType>
    <!-- Don't copy referenced projects' .pdb/.xml alongside the single file. -->
    <AllowedReferenceRelatedFileExtensions>none</AllowedReferenceRelatedFileExtensions>
    <!-- WPF is not trim-safe; do not trim. -->
    <PublishTrimmed>false</PublishTrimmed>
    <PublishReadyToRun>false</PublishReadyToRun>
    <!-- Keep only English satellites (SqlClient ships many localized resource assemblies). -->
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
  </PropertyGroup>
</Project>
