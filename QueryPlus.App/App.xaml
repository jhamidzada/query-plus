<Application x:Class="QueryPlus.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Fluent (Win11-style) theming for all standard controls. Light theme keeps
                     the AvalonEdit editor (white background) visually consistent. -->
                <ui:ThemeResources RequestedTheme="Light" />
                <ui:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />

            <!-- Soften list/tree/grid selection: the theme's accent selection is too dark and
                 stays saturated when focus leaves. These lighter blues keep dark text readable
                 and make a lingering selection subtle. (Direct entries override the merged
                 theme dictionaries at lookup time.) -->
            <SolidColorBrush x:Key="SystemControlHighlightListAccentLowBrush" Color="#FFCCE4F7" />
            <SolidColorBrush x:Key="SystemControlHighlightListAccentMediumBrush" Color="#FFB9D9F2" />
            <SolidColorBrush x:Key="SystemControlHighlightListAccentHighBrush" Color="#FFA6CDEC" />

            <!-- Compact checkbox for bare (label-less) checkboxes in item rows: the theme's
                 CheckBox defaults to MinWidth=120/MinHeight=32, which wrecks row layout. -->
            <Style x:Key="CompactCheckBox" TargetType="CheckBox" BasedOn="{StaticResource DefaultCheckBoxStyle}">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
