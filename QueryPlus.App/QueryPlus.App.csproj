<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- The exe/assembly is "QueryPlus" (not "QueryPlus.App") for a clean shippable name. -->
    <AssemblyName>QueryPlus</AssemblyName>
    <ApplicationIcon>AppIcon.ico</ApplicationIcon>
    <AssemblyTitle>QueryPlus</AssemblyTitle>
    <Product>QueryPlus</Product>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
    <PackageReference Include="AvalonEdit" Version="6.3.1.120" />
    <PackageReference Include="ModernWpfUI" Version="0.9.6" />
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="8.0.0" />
    <PackageReference Include="DocumentFormat.OpenXml" Version="3.1.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\QueryPlus.Core\QueryPlus.Core.csproj" />
  </ItemGroup>

</Project>
